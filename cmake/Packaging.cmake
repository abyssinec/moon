set(CPACK_PACKAGE_NAME "Moon Audio Editor")
set(CPACK_PACKAGE_VENDOR "Moon Dev")
set(CPACK_PACKAGE_CONTACT "local-first@moon.dev")
set(CPACK_PACKAGE_VERSION "${PROJECT_VERSION}")
set(CPACK_PACKAGE_INSTALL_DIRECTORY "MoonAudioEditor")
set(CPACK_PACKAGE_FILE_NAME "MoonAudioEditor-${PROJECT_VERSION}-${CMAKE_SYSTEM_NAME}")
set(CPACK_MONOLITHIC_INSTALL ON)
set(CPACK_RESOURCE_FILE_LICENSE "${CMAKE_CURRENT_SOURCE_DIR}/README.md")

set(CPACK_GENERATOR "ZIP")
if (WIN32)
    list(APPEND CPACK_GENERATOR "NSIS")
    set(CPACK_NSIS_DISPLAY_NAME "Moon Audio Editor")
    set(CPACK_NSIS_PACKAGE_NAME "Moon Audio Editor")
    set(CPACK_NSIS_MODIFY_PATH ON)
endif()

include(CPack)
